<Window x:Class="CyberSecurityChatbotGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CyberSecurityChatbotGUI"
        mc:Ignorable="d"
        Title="Cybersecurity Awareness Chatbot"
        Height="500"
        Width="800">

    <Grid Background="#0F172A">

        <StackPanel Margin="20">

            <TextBlock Text="CYBERSECURITY AWARENESS CHATBOT"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="Cyan"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20"/>

            <TextBox x:Name="ChatDisplay"
                     Height="250"
                     IsReadOnly="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     FontSize="16"
                     Background="Black"
                     Foreground="Lime"
                     Margin="0,0,0,10"/>

            <TextBox x:Name="UserInput"
                     Height="40"
                     FontSize="16"
                     Margin="0,0,0,10"/>

            <Button Content="Send"
                    Height="40"
                    Width="120"
                    HorizontalAlignment="Center"
                    Background="Cyan"
                    FontWeight="Bold"
                    Click="SendButton_Click"/>

        </StackPanel>

    </Grid>

</Window>